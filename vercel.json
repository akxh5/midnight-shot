{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/managed/(.*)",
      "destination": "/managed/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!managed/|assets/|favicon.ico|vite.svg).*\\..*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
